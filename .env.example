# Apple ID credentials for the AirTag key extraction VM flow.
# Copy this file to .env and fill in your values.
# .env is loaded automatically by Docker Compose (env_file in compose.yaml).
# Both fields are optional — if left out, the browser UI prompts for them.

AIRTAG_APPLE_EMAIL=your@icloud.com
AIRTAG_APPLE_PASSWORD=your-app-specific-password
# Last 4+ digits of the phone number Apple should SMS the 2FA code to.
# If your Apple ID has multiple trusted numbers, set this so the automation
# picks the right one (e.g. AIRTAG_SMS_PHONE_SUFFIX=1234).
AIRTAG_SMS_PHONE_SUFFIX=
# iPhone passcode needed to approve iCloud data sync on a new Mac.
# macOS shows "Some iCloud Data Isn't Syncing" and asks for this PIN to unlock
# iCloud Keychain, which is required for OwnedBeacons (AirTag keys) to sync.
AIRTAG_IPHONE_PASSCODE=

# Set to true to automatically trigger a runtime run every AIRTAG_POLL_INTERVAL
# seconds (default 900 = 15 min). Requires credentials above to be set.
AIRTAG_AUTO_RUN=false

# How often (seconds) the scheduler triggers a run. Default: 900 (15 min).
AIRTAG_POLL_INTERVAL=900

# Public URL of the noVNC web interface ("Open VM" button in the UI).
# Leave empty for local use (defaults to http://localhost:6901).
# Set to e.g. https://airtag-vnc.example.com when behind a reverse proxy.
AIRTAG_VNC_URL=
